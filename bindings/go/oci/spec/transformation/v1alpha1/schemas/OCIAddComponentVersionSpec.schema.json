          "properties": {
            "algorithm": {
              "description": "Algorithm used for merging labels",
              "pattern": "^[a-z][a-z0-9/_-]+$"
            },
            "config": {
              "description": "Configuration specific to the merge algorithm"
            }
          },
          "additionalProperties": false
        },
        "meta": {
          "type": "object",
