              "type": "array",
              "items": {
                "$ref": "#/$defs/nestedComponentDigests"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "signatures": {
          "description": "Optional signing information for verifying component validity",
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/signature"
              }
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "meta",
        "component"
