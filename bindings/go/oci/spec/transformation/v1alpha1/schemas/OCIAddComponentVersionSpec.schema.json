            "labels": {
              "description": "Labels associated with the resource",
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/label"
                  }
                },
                {
                  "type": "null"
                }
              ]
            },
            "name": {
              "type": "string",
              "$ref": "#/$defs/identityAttributeKey",
              "description": "Name of the resource"
            },
            "relation": {
              "type": "string",
              "description": "Relation of the resource to the component (local or external)",
              "enum": [
                "local",
                "external"
              ]
