# Controller-specific overrides
# These values override the project root .env if needed
# Leave empty to use project defaults managed by renovate

# renovate: datasource=go depName=sigs.k8s.io/controller-tools
CONTROLLER_TOOLS_VERSION=v0.21.0

# renovate: datasource=custom.envtest depName=envtest
ENVTEST_K8S_VERSION=1.36.0
ENVTEST_VERSION=release-0.21

# renovate: datasource=docker depName=kindest/node
KIND_NODE_IMAGE_VERSION=1.35.1