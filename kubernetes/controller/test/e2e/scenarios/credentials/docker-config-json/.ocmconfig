type: generic.config.ocm.software/v1
configurations:
  - type: credentials.config.ocm.software
    consumers:
      # Required for transfer to the registry (outside the cluster)
      - identity:
          type: OCIRegistry
          hostname: localhost
          scheme: http
          port: "31003"
        credentials:
          - type: Credentials
            properties:
              username: admin2
              password: admin2
