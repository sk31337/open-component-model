# Host-side credentials used by the e2e test to verify the replicated component
# via the external NodePort of the target registry (localhost:31002).
type: generic.config.ocm.software/v1
configurations:
  - type: credentials.config.ocm.software
    consumers:
      - identity:
          type: OCIRegistry
          hostname: localhost
          scheme: http
          port: "31002"
        credentials:
          - type: Credentials
            properties:
              username: admin
              password: admin
      - identity:
          type: OCIRepository
          hostname: localhost
          scheme: http
          port: "31002"
        credentials:
          - type: Credentials
            properties:
              username: admin
              password: admin
